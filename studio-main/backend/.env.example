# =============================================================================
#  EduIgnite Backend – Environment Variables
#  Copy this file to .env and fill in real values before starting the server.
#  NEVER commit .env to version control.
# =============================================================================

# ── Django core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-replace-this-with-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=eduignite.com,www.eduignite.com,api.eduignite.com
ENVIRONMENT=production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Option A – single connection string (recommended for Railway / Render)
DATABASE_URL=postgresql://eduignite_user:EduIgnite_DB_2026!@localhost:5432/eduignite

# Option B – individual variables (used if DATABASE_URL is not set)
# DB_NAME=eduignite
# DB_USER=eduignite_user
# DB_PASSWORD=EduIgnite_DB_2026!
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSL_REQUIRE=True
DB_CONN_MAX_AGE=600

# ── Redis ─────────────────────────────────────────────────────────────────────
# Option A – single URL (recommended)
REDIS_URL=redis://localhost:6379/1

# Option B – individual variables
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=eduignitecmr@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=EduIgnite <eduignitecmr@gmail.com>
SERVER_EMAIL=eduignitecmr@gmail.com
FRONTEND_URL=https://eduignite.com

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789012345678901
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account

# ── Groq AI ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
AI_REQUEST_MONTHLY_LIMIT=500
AI_REQUEST_DAILY_LIMIT=50

# ── AWS S3 (optional – for media file storage) ────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=eduignite-media
AWS_S3_REGION_NAME=eu-west-1
# AWS_S3_CUSTOM_DOMAIN=cdn.eduignite.com   # optional CloudFront domain

# ── Security (production) ────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CSRF_TRUSTED_ORIGINS=https://eduignite.com,https://www.eduignite.com,https://api.eduignite.com
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://eduignite.com,https://www.eduignite.com

# ── Error tracking (optional) ────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Django settings module ────────────────────────────────────────────────────
# Use 'config.settings.development' locally, 'config.settings.production' on server
DJANGO_SETTINGS_MODULE=config.settings.production
